---
layout: layouts/page.njk
title: "All Tags | Gunther Cox"
description: "Browse all topics and tags from the blog."
permalink: /blog/tags/index.html
---
<section class="feature-row">
  <div>
    <p class="eyebrow"><a href="/blog/" class="footer-link">&larr; All posts</a></p>
    <h1 class="mt-2 text-3xl font-semibold">All Tags</h1>
    <p class="mt-3 max-w-3xl text-muted">Browse posts by topic.</p>
  </div>
</section>

<section class="grid-card">
  <div class="flex flex-wrap gap-3">
    {% for tag in collections.tagList %}
    <a href="/blog/tags/{{ tag | slug }}/" class="muted-chip hover:opacity-80 transition-opacity">{{ tag }}</a>
    {% endfor %}
  </div>
</section>
