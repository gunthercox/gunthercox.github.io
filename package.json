{
  "name": "gunthercox-com",
  "private": true,
  "version": "1.0.0",
  "description": "Static personal site built with Tailwind CSS and Eleventy",
  "scripts": {
    "build": "tailwindcss -i ./src/styles.css -o ./assets/styles.css && ./node_modules/.bin/eleventy",
    "build:prod": "tailwindcss -i ./src/styles.css -o ./assets/styles.css --minify && ./node_modules/.bin/eleventy",
    "watch": "tailwindcss -i ./src/styles.css -o ./assets/styles.css --watch & ./node_modules/.bin/eleventy --watch",
    "eleventy": "./node_modules/.bin/eleventy",
    "eleventy:watch": "./node_modules/.bin/eleventy --watch"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-rss": "^2.0.3",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0"
  }
}
